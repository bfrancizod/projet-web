# Fichier d'exemple de configuration — copier ce fichier en .env et remplir les valeurs.
# Le fichier .env réel est dans .gitignore et ne doit jamais être versionné (contient des secrets).
#
# Utilisation :
#   cp .env.example .env
# Puis remplir chaque variable avec les vraies valeurs de votre environnement.

# ── Base de données MySQL ──────────────────────────────────────────────────────
# Hôte du serveur MySQL (ex: localhost en local, ou l'URL Railway en cloud)
DB_HOST=localhost

# Port MySQL (3306 par défaut en local, Railway donne un port aléatoire)
DB_PORT=3306

# Nom de la base de données
DB_NAME=helpmestage

# Nom d'utilisateur MySQL
DB_USER=root

# Mot de passe MySQL
DB_PASS=
