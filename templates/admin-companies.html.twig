{#
    Liste paginée des entreprises — accessible aux pilotes ET admins.

    Variables transmises par AdminCompanyController :
     - companies       : entreprises de la page courante (nom, secteur, ville, note, site_web…)
     - search          : texte de recherche en cours
     - total_companies : nombre total d'entreprises correspondant au filtre
     - current_page    : numéro de page actuelle
     - total_pages     : nombre total de pages
     - current_user    : utilisateur connecté (sert à choisir le lien « Retour »)
     - csrf_token      : jeton anti-CSRF pour les formulaires de suppression

    Permet de rechercher, créer, modifier/évaluer et supprimer une entreprise.
#}
{% extends 'base.html.twig' %}

{% block title %}Gestion des entreprises{% endblock %}

{# pilot-dashboard.css pour la mise en page, star-rating.css pour l'affichage des étoiles de note #}
{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pilot-dashboard.css">
    <link rel="stylesheet" href="/assets/css/star-rating.css">
{% endblock %}

{% block body %}
<div class="pilot-page">
    <div class="pilot-container">
        <section class="activity-section">
            {# En-tête : titre + boutons d'action (créer, retour dashboard) #}
            <div class="activity-header">
                <h2>Gestion des entreprises</h2>

                <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                    <a href="/admin-entreprise-create" class="student-button">Créer une entreprise</a>

                    {# Le lien de retour dépend du rôle : admin → espace admin, pilote → espace pilote #}
                    {% if current_user.role == 'administrateur' %}
                        <a href="/espace-admin">Retour au dashboard</a>
                    {% else %}
                        <a href="/espace-pilote">Retour au dashboard</a>
                    {% endif %}
                </div>
            </div>

            {# Formulaire de recherche (méthode GET → le terme reste dans l'URL, partageable) #}
            <form method="GET" action="/admin-entreprises" class="apply-form" style="margin-bottom: 18px;">
                <label for="q">Rechercher une entreprise</label>

                <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                    {# value="{{ search }}" : conserve le terme saisi après soumission #}
                    <input
                        id="q"
                        name="q"
                        type="text"
                        value="{{ search }}"
                        placeholder="Nom, secteur, ville"
                        autocomplete="off"
                    >

                    <button type="submit" class="student-button">Rechercher</button>
                    {# « Réinitialiser » = lien vers l'URL sans paramètre de recherche #}
                    <a href="/admin-entreprises" class="student-button">Réinitialiser</a>
                </div>
            </form>

            {# Compteur de résultats — accord singulier/pluriel géré via l'opérateur ternaire #}
            {% if total_companies is defined %}
                <p style="margin-bottom:16px; color:#6b7280;">
                    {{ total_companies }} entreprise{{ total_companies > 1 ? 's' : '' }} trouvée{{ total_companies > 1 ? 's' : '' }}
                </p>
            {% endif %}

            {# Liste des entreprises : une <article> par entreprise #}
            <div class="student-list">
                {% for company in companies %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ company.nom }}</h3>

                            {# Secteur et ville, avec valeur de repli si le champ est vide (filtre ?:) #}
                            <p>
                                {{ company.secteur ?: 'Secteur non défini' }}
                                • {{ company.ville ?: 'Ville non définie' }}
                            </p>

                            <div class="student-meta">
                                {# Affichage de la note : 5 étoiles si évaluée, badge sinon #}
                                {% if company.note is not null %}
                                    <span class="stars-display">
                                        {# Arrondi à l'entier inférieur pour savoir combien d'étoiles remplir #}
                                        {% set note_int = company.note|round(0, 'floor') %}

                                        {# Boucle de 1 à 5 : étoile pleine si i <= note, vide sinon (&#9733; = ★) #}
                                        {% for i in 1..5 %}
                                            <span class="star-icon {% if i <= note_int %}star-filled{% else %}star-empty{% endif %}">&#9733;</span>
                                        {% endfor %}

                                        <small class="stars-number">{{ note_int }}/5</small>
                                    </span>
                                {% else %}
                                    {# Pas encore de note attribuée #}
                                    <span class="badge badge-yellow">Non évaluée</span>
                                {% endif %}

                                {# Site web ou texte de repli si absent #}
                                <small>{{ company.site_web ?: 'Aucun site web' }}</small>
                            </div>

                            {# Commentaire interne facultatif (affiché seulement s'il existe et n'est pas vide) #}
                            {% if company.commentaire is defined and company.commentaire %}
                                <p style="margin-top:8px; color:#374151;">💬 {{ company.commentaire }}</p>
                            {% endif %}
                        </div>

                        {# Actions sur l'entreprise : éditer/évaluer et supprimer #}
                        <div class="student-actions student-actions-vertical">
                            <a href="/admin-entreprises/{{ company.id }}/editer" class="student-button">
                                Modifier / Évaluer
                            </a>

                            {# Suppression via POST (jamais GET) + confirmation JS + jeton CSRF #}
                            <form
                                method="POST"
                                action="/admin-entreprises/{{ company.id }}/supprimer"
                                onsubmit="return confirm('Confirmer la suppression ?');"
                            >
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="student-button">Supprimer</button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    {# Bloc {% else %} d'un {% for %} : s'affiche si la liste est vide #}
                    <p class="empty-state">Aucune entreprise trouvée.</p>
                {% endfor %}
            </div>

            {# Barre de pagination — affichée seulement s'il y a plus d'une page #}
            {% if total_pages is defined and total_pages > 1 %}
                <nav style="display:flex; justify-content:center; gap:10px; margin-top:24px; flex-wrap:wrap;">
                    {# Bouton « Précédent » masqué sur la première page #}
                    {% if current_page > 1 %}
                        <a
                            class="student-button"
                            href="/admin-entreprises?page={{ current_page - 1 }}{% if search %}&q={{ search|url_encode }}{% endif %}"
                        >
                            Précédent
                        </a>
                    {% endif %}

                    {# Indicateur de position « Page X / Y » #}
                    <span style="display:flex; align-items:center; color:#374151;">
                        Page {{ current_page }} / {{ total_pages }}
                    </span>

                    {# Bouton « Suivant » masqué sur la dernière page #}
                    {# url_encode sur la recherche : préserve le filtre en changeant de page #}
                    {% if current_page < total_pages %}
                        <a
                            class="student-button"
                            href="/admin-entreprises?page={{ current_page + 1 }}{% if search %}&q={{ search|url_encode }}{% endif %}"
                        >
                            Suivant
                        </a>
                    {% endif %}
                </nav>
            {% endif %}
        </section>
    </div>
</div>
{% endblock %}