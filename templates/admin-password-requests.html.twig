{% extends 'base.html.twig' %}

{% block title %}Demandes de mot de passe - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/admin-dashboard.css">
    <link rel="stylesheet" href="/assets/css/login.css">
{% endblock %}

{% block body %}
<main class="admin-dashboard-page">
    <h1 class="admin-dashboard-title">Demandes de mot de passe</h1>
    <p class="admin-dashboard-subtitle">
        Gérez les demandes de réinitialisation et modifiez le mot de passe des utilisateurs concernés.
    </p>

    {% if success %}
        <p class="login-success">Mot de passe modifié avec succès.</p>
    {% endif %}

    {% if error %}
        <p class="login-error">{{ error }}</p>
    {% endif %}

    <section class="admin-recent-section">
        <h2>Demandes reçues</h2>

        <div class="admin-student-list">
            {% for request in requests %}
                <article class="admin-student-row">
                    <h3>{{ request.email }}</h3>

                    <p>
                        Statut : {{ request.status }}
                        — Demande faite le {{ request.created_at|date('d/m/Y H:i') }}
                    </p>

                    {% if request.status == 'traitee' %}
                        <small>Traitée le {{ request.processed_at|date('d/m/Y H:i') }}</small>
                    {% elseif request.user_id %}
                        <form method="POST" action="/admin-demandes-mdp/{{ request.id }}/changer" class="login-form" novalidate>
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                            <label for="password-{{ request.id }}">Nouveau mot de passe</label>
                            <input
                                id="password-{{ request.id }}"
                                type="password"
                                name="password"
                                required
                                minlength="8"
                                placeholder="Nouveau mot de passe"
                            >

                            <button type="submit" class="admin-action-button">
                                Modifier le mot de passe
                            </button>
                        </form>
                    {% else %}
                        <p class="login-error">
                            Aucun compte utilisateur trouvé avec cet email.
                        </p>
                    {% endif %}
                </article>
            {% else %}
                <p class="admin-empty">Aucune demande de mot de passe.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}