{#
    Formulaire de création / édition d'un pilote (mutualisé via is_edit).

    Variables transmises par AdminPilotController::handleForm() :
     - pilot         : données pré-remplies (dont pilot.promotion_ids[] pour les checkboxes)
     - promotions    : toutes les promotions actives
     - is_edit       : booléen
     - error / success

    Les checkboxes name="promotion_ids[]" envoient un tableau de strings.
    Le contrôleur les filtre via ctype_digit() + array_unique() avant de sauvegarder.
    Le mot de passe n'est affiché qu'en création — il n'est pas modifiable en édition.
#}
{% extends 'base.html.twig' %}

{% block title %}
    {% if is_edit %}
        Modifier le pilote
    {% else %}
        Créer un pilote
    {% endif %}
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/student-dashboard.css">
{% endblock %}

{% block body %}
<div class="student-page">
    <div class="student-container">
        <section class="student-section">
            <div class="student-section-header">
                <h2>
                    {% if is_edit %}
                        Modifier le pilote
                    {% else %}
                        Créer un pilote
                    {% endif %}
                </h2>
                <a href="/admin-pilotes">Retour</a>
            </div>

            {% if error %}
                <p class="empty-state" style="color:#b91c1c;">{{ error }}</p>
            {% endif %}

            {% if success %}
                <p class="empty-state" style="color:#15803d;">{{ success }}</p>
            {% endif %}

            <form
                method="POST"
                action="{% if is_edit %}/admin-pilotes/{{ pilot.id }}/editer{% else %}/admin-pilote-create{% endif %}"
                class="apply-form"
            >
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <label for="nom">Nom *</label>
                <input id="nom" type="text" name="nom" value="{{ pilot.nom }}" required maxlength="100">

                <label for="prenom">Prénom *</label>
                <input id="prenom" type="text" name="prenom" value="{{ pilot.prenom }}" required maxlength="100">

                <label for="email">Email *</label>
                <input id="email" type="email" name="email" value="{{ pilot.email }}" required maxlength="255">

                <fieldset style="border:1px solid #d6d3d1; border-radius:12px; padding:16px; margin:16px 0;">
                    <legend style="padding:0 8px; font-weight:700;">Promotions rattachées *</legend>

                    <div style="display:grid; gap:10px;">
                        {% for promotion in promotions %}
                            <label style="display:flex; align-items:center; gap:10px; margin:0; font-weight:500;">
                                <input
                                    type="checkbox"
                                    name="promotion_ids[]"
                                    value="{{ promotion.id }}"
                                    {% if promotion.id in pilot.promotion_ids %}checked{% endif %}
                                >
                                <span>{{ promotion.label }} — {{ promotion.academic_year }}</span>
                            </label>
                        {% else %}
                            <p class="empty-state">Aucune promotion active disponible.</p>
                        {% endfor %}
                    </div>
                </fieldset>

                {% if not is_edit %}
                    <label for="password">Mot de passe initial *</label>
                    <input id="password" type="password" name="password" required minlength="8">
                {% endif %}

                <button type="submit" class="cta-button">
                    {% if is_edit %}
                        Enregistrer les modifications
                    {% else %}
                        Créer le pilote
                    {% endif %}
                </button>
            </form>
        </section>
    </div>
</main>
{% endblock %}