{#
    Formulaire de candidature à une offre.

    Variables transmises par ApplyController::form() :
     - offer          : données de l'offre (id, titre) pour l'action du formulaire
     - already_applied: booléen — l'étudiant a déjà postulé → affiche un message d'avertissement
     - error          : message d'erreur de validation (null si aucune erreur)

    Le formulaire utilise enctype="multipart/form-data" pour l'upload du CV (PDF).
    La validation côté serveur vérifie : type MIME réel via finfo (magic bytes, pas l'extension),
    taille max 2 Mo, quota de 20 CVs par étudiant.
#}
{% extends 'base.html.twig' %}

{% block title %}Postuler - {{ offer.titre }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="/assets/css/apply.css">
{% endblock %}

{% block body %}
<main class="apply-page">
    <div class="apply-container">

        <h1>Postuler à cette offre</h1>

        {% if already_applied %}
            <div class="apply-alert apply-alert-warning">
                Vous avez déjà postulé à cette offre.
            </div>
        {% else %}

            {% if error %}
                <div class="apply-alert apply-alert-error">
                    {{ error }}
                </div>
            {% endif %}

            <form method="POST"
                  action="/offres/{{ offer.id }}/postuler"
                  enctype="multipart/form-data"
                  class="apply-form">

                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <label for="lettre_motivation">Lettre de motivation *</label>
                <textarea id="lettre_motivation" name="lettre_motivation" required minlength="20"></textarea>

                <label for="cv">CV (PDF - max 2Mo) *</label>
                <input type="file"
                       id="cv"
                       name="cv"
                       accept="application/pdf"
                       required>

                <div class="apply-actions-row">
                    <button type="submit" class="cta-button">
                        Envoyer ma candidature
                    </button>
                </div>

            </form>
        {% endif %}
    </div>
</main>

{% block javascripts %}
    <script src="/assets/js/apply-cv-validation.js"></script>
{% endblock %}
{% endblock %}