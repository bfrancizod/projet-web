{% extends 'base.html.twig' %}

{% block title %}Postuler - {{ offer.titre }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="/assets/css/apply.css">
{% endblock %}

{% block body %}
<main class="apply-page">
    <div class="apply-container">

        <h1>Postuler à cette offre</h1>

        {% if already_applied %}
            <div class="apply-alert apply-alert-warning">
                Vous avez déjà postulé à cette offre.
            </div>
        {% else %}

            {% if error %}
                <div class="apply-alert apply-alert-error">
                    {{ error }}
                </div>
            {% endif %}

            <form method="POST"
                  action="/offres/{{ offer.id }}/postuler"
                  enctype="multipart/form-data"
                  class="apply-form">

                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <label>Lettre de motivation *</label>
                <textarea name="lettre_motivation" required minlength="20"></textarea>

                <label>CV (PDF - max 2Mo) *</label>
                <input type="file"
                       name="cv"
                       accept="application/pdf"
                       required>

                <div class="apply-actions-row">
                    <button type="submit" class="cta-button">
                        Envoyer ma candidature
                    </button>
                </div>

            </form>
        {% endif %}
    </div>
</main>
{% endblock %}