{#
    Template de base — hérité par tous les autres templates via "extends 'base.html.twig'".

    Blocs disponibles pour les templates enfants :
     - block title       : titre de l'onglet (défaut : "Help Me Stage")
     - block stylesheets : feuilles CSS spécifiques à la page
     - block body        : contenu principal de la page
     - block javascripts : scripts JS spécifiques à la page (chargés avant </body>)

    Variables globales injectées par index.php pour tous les templates :
     - current_user      : tableau utilisateur connecté (null si visiteur)
     - csrf_token        : token CSRF pour les formulaires
     - show_cookie_banner: booléen déclenchant le banner RGPD
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    {# block title : chaque page enfant peut surcharger le titre de l'onglet #}
    <title>{% block title %}Help Me Stage{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Favicon -->
    <link rel="icon" href="/assets/logo/logo.svg" type="image/svg+xml">

    {# base.css est chargé en premier sur toutes les pages (variables CSS, reset, composants communs) #}
    <link rel="stylesheet" href="/assets/css/base.css">
    {# block stylesheets : les templates enfants y ajoutent leur CSS spécifique #}
    {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="site-header">
    <div class="container header-content">

        <!-- LOGO -->
        <div class="logo">
            <a href="/" class="logo-link">
                <img 
                    src="/assets/logo/logo.svg"
                    alt="Help Me Stage"
                    class="site-logo"
                >
                <span class="site-logo-text">Help Me Stage</span>
            </a>
        </div>

        <div class="header-right">
            {% if current_user %}
                <span class="connected-user">
                    {{ current_user.email }}
                </span>
            {% endif %}

            <button class="menu-button" id="menu-toggle" aria-label="Ouvrir le menu">☰</button>
        </div>

    </div>

    {#
        Menu de navigation — affiché/masqué via le bouton hamburger (JS ci-dessous).
        Les liens sont conditionnels selon le rôle de current_user :
         - administrateur : accès à l'espace admin, offres, statistiques
         - pilote          : accès à l'espace pilote, offres, statistiques
         - etudiant        : accès à l'espace étudiant, candidatures, wishlist, offres, statistiques
         - visiteur (null) : liens publics uniquement (accueil, offres, connexion)
    #}
    <nav class="mobile-menu" id="mobile-menu">
        {% if current_user %}

            {% if current_user.role == 'administrateur' %}
                <a href="/espace-admin">Mon espace administrateur</a>
                <a href="/offres">Voir les offres</a>
                <a href="/statistiques-offres">Statistiques</a>
                <a href="/logout">Déconnexion</a>

            {% elseif current_user.role == 'pilote' %}
                <a href="/espace-pilote">Mon espace pilote</a>
                <a href="/offres">Voir les offres</a>
                <a href="/statistiques-offres">Statistiques</a>
                <a href="/logout">Déconnexion</a>

            {% elseif current_user.role == 'etudiant' %}
                <a href="/espace-etudiant">Mon espace étudiant</a>
                <a href="/etudiant-candidatures">Mes candidatures</a>
                <a href="/etudiant-wishlist">Ma wishlist</a>
                <a href="/offres">Voir les offres</a>
                <a href="/statistiques-offres">Statistiques</a>
                <a href="/logout">Déconnexion</a>
            {% endif %}

        {% else %}
            {# Visiteur non connecté : liens publics uniquement #}
            <a href="/">Accueil</a>
            <a href="/offres">Voir les offres</a>
            <a href="/connexion">Connexion</a>
        {% endif %}
    </nav>
</header>

<main class="site-main">
    {# block body : chaque template enfant injecte son contenu ici #}
    {% block body %}{% endblock %}
</main>

<footer class="site-footer">
    <div class="container footer-content">

        <div class="footer-brand">
            <a href="/" class="footer-logo-link">
                <img 
                    src="/assets/logo/logo.svg"
                    alt="Help Me Stage"
                    class="footer-logo"
                >
                <span class="footer-brand-text">Help Me Stage</span>
            </a>
            <p class="footer-description">
                Plateforme de mise en relation entre étudiants et offres de stage.
            </p>
        </div>

        <div class="footer-links">
            <div class="footer-column">
                <h3>Navigation</h3>
                <a href="/">Accueil</a>
                <a href="/offres">Offres</a>
                <a href="/contact">Contact</a>
            </div>

            <div class="footer-column">
                <h3>Informations</h3>
                <a href="/mentions-legales">Mentions légales</a>
                <a href="/politique-confidentialite">Politique de confidentialité</a>
            </div>
        </div>

    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-content">
            {# "now"|date("Y") : filtre Twig qui formate la date courante → affiche l'année dynamiquement #}
            <p>© {{ "now"|date("Y") }} Help Me Stage - Tous droits réservés.</p>
        </div>
    </div>
</footer>

<script>
{# Toggle du menu mobile : ajoute/retire la classe CSS "is-open" sur le nav #}
document.getElementById('menu-toggle')?.addEventListener('click', function () {
    document.getElementById('mobile-menu').classList.toggle('is-open');
});
</script>

{# block javascripts : les templates enfants y ajoutent leurs scripts spécifiques à la page #}
{% block javascripts %}{% endblock %}

</body>
</html>