{#
    Page « Mot de passe oublié » — accessible publiquement (utilisateur non connecté).

    Variables transmises par AuthController :
     - success    : booléen, vrai une fois la demande enregistrée
     - error      : message d'erreur éventuel (email invalide, etc.)
     - csrf_token : jeton anti-CSRF pour sécuriser le formulaire POST

    Principe : l'utilisateur ne réinitialise PAS son mot de passe lui-même.
    Il envoie une demande ; un administrateur la traite ensuite manuellement
    (voir admin-password-requests.html.twig).
#}
{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Help Me Stage{% endblock %}

{# Réutilise la feuille de style de la page de connexion (même mise en page « carte ») #}
{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/login.css">
{% endblock %}

{% block body %}
<div class="login-page">
    <section class="login-section">
        <div class="login-card">
            <h1>Mot de passe oublié</h1>

            {# Deux états mutuellement exclusifs : confirmation (success) OU formulaire #}
            {% if success %}
                {# --- État 1 : la demande vient d'être enregistrée --- #}
                <p class="login-success">
                    Votre demande a bien été transmise. Un administrateur prendra en charge la réinitialisation de votre mot de passe.
                </p>

                <p class="login-note">
                    <a href="/connexion">Retour à la connexion</a>
                </p>
            {% else %}
                {# --- État 2 : formulaire de saisie de l'email --- #}
                <p class="login-note">
                    Saisissez votre email. L’administrateur sera averti de votre demande.
                </p>

                {# Affiche le message d'erreur seulement s'il y en a un (email inconnu/invalide) #}
                {% if error %}
                    <p class="login-error">{{ error }}</p>
                {% endif %}

                {# Formulaire POST : le champ caché _csrf_token protège contre les attaques CSRF #}
                <form method="POST" action="/mot-de-passe-oublie" class="login-form">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                    {# Champ email : type="email" + required = validation native du navigateur #}
                    <label for="email">Email</label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        placeholder="prenom.nom@helpmestage.fr"
                        required
                        maxlength="255"
                        autocomplete="email"
                    >

                    <button type="submit" class="cta-button login-button">
                        Envoyer la demande
                    </button>
                </form>

                {# Lien de secours pour revenir à la page de connexion sans envoyer de demande #}
                <p class="login-note">
                    <a href="/connexion">Retour à la connexion</a>
                </p>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}