{#
    Page d'accueil publique.

    Variables transmises par HomeController::index() :
     - hero_title : titre de la section hero (ex: "Trouvez votre stage idéal")
     - hero_text  : sous-titre descriptif
     - steps      : tableau d'étapes [{icon, title, text}] pour la section "Comment ça marche ?"
#}
{% extends 'base.html.twig' %}

{% block title %}Accueil - Help Me Stage{% endblock %}
{% block meta_description %}Help Me Stage — trouvez votre stage idéal. Plateforme de mise en relation entre étudiants et entreprises.{% endblock %}
{% block og_title %}Help Me Stage — Trouvez votre stage{% endblock %}
{% block og_description %}Consultez les offres de stage, postulez en ligne et gérez vos candidatures sur Help Me Stage.{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="/assets/css/home.css">
{% endblock %}

{% block body %}
<div>

<section class="hero">
    <div class="container hero-inner">
        <h1>{{ hero_title }}</h1>
        <p>{{ hero_text }}</p>
        <a href="/offres" class="cta-button">Voir les offres</a>
    </div>
</section>

<section class="steps-section" id="comment-ca-marche">
    <div class="container">
        <h2>Comment ça marche ?</h2>

        {# Boucle sur le tableau steps défini dans HomeController — 3 cartes par défaut #}
        <div class="steps-grid">
            {% for step in steps %}
                <article class="step-card">
                    <div class="step-icon">{{ step.icon }}</div>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.text }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

</main>
{% endblock %}