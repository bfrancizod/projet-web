{#
    Page de connexion.

    Variables transmises par AuthController::login() :
     - error : message d'erreur en cas d'identifiants incorrects (null sinon)
               Le message est intentionnellement vague ("Identifiants incorrects") pour
               éviter l'énumération des comptes (ne pas révéler si l'email existe).

    Notes :
     - Le formulaire utilise novalidate pour désactiver la validation HTML native
       (la validation côté serveur est suffisante et plus fiable).
     - Le lien "Mot de passe oublié ?" est un placeholder (fonctionnalité à implémenter).
#}
{% extends 'base.html.twig' %}

{% block title %}Connexion - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/login.css">
{% endblock %}

{% block body %}
<main class="login-page">
    <section class="login-section">
        <div class="login-card">
            <h1>Connexion</h1>

            <div class="demo-box demo-student">
                <strong>Compte Étudiant :</strong><br>
                Email : etudiant@helpmestage.fr<br>
                Mot de passe : stage2026
            </div>

            <div class="demo-box demo-pilot">
                <strong>Compte Pilote de formation :</strong><br>
                Email : pilote@helpmestage.fr<br>
                Mot de passe : pilote2026
            </div>

            <div class="demo-box demo-admin">
                <strong>Compte Administrateur :</strong><br>
                Email : admin@helpmestage.fr<br>
                Mot de passe : admin2026
            </div>

            {# Message d'erreur générique — ne précise pas si c'est l'email ou le mot de passe #}
            {% if error %}
                <p class="login-error">{{ error }}</p>
            {% endif %}

            <form method="POST" action="/connexion" class="login-form" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <label for="email">Email</label>
                <input
                    id="email"
                    name="email"
                    type="email"
                    placeholder="admin@helpmestage.fr"
                    required
                    maxlength="255"
                    autocomplete="email"
                >

                <label for="password">Mot de passe</label>
                <input
                    id="password"
                    name="password"
                    type="password"
                    placeholder="********"
                    required
                    autocomplete="current-password"
                >

                <div class="forgot-password">
                    <a href="#">Mot de passe oublié ?</a>
                </div>

                <button type="submit" class="cta-button login-button">
                    Se connecter
                </button>
            </form>

            <p class="login-note">
                En vous connectant, vous acceptez nos conditions d’utilisation
            </p>
        </div>
    </section>
</main>
{% endblock %}