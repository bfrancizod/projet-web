{% extends 'base.html.twig' %}

{% block title %}{{ offer.titre }} - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/offer-detail.css">
    <link rel="stylesheet" href="/assets/css/star-rating.css">
{% endblock %}

{% block body %}
<main class="offer-detail-page">
    <div class="container">
        <nav class="breadcrumb">
            <a href="/">Accueil</a>
            <span>/</span>
            <a href="/offres">Offres</a>
            <span>/</span>
            <span>{{ offer.titre }}</span>
        </nav>

        <section class="offer-detail-card">
            <h1>{{ offer.titre }}</h1>

            <p class="detail-company">{{ offer.entreprise_nom ?: 'Entreprise non définie' }}</p>

            <div class="detail-info-grid">
                <div class="detail-info-item">
                    <span class="detail-label">Rémunération</span>
                    <strong>{{ offer.remuneration }} € / mois</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Lieu</span>
                    <strong>{{ offer.lieu ?: 'Non défini' }}</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Durée</span>
                    <strong>{{ offer.duree_semaines }} semaines</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Publication</span>
                    <strong>{{ offer.created_at|date('d/m/Y') }}</strong>
                </div>
            </div>

            <h2>Description de l'offre</h2>
            <p class="detail-description">{{ offer.description }}</p>

            <h2>Entreprise</h2>
            <div class="detail-info-grid">
                <div class="detail-info-item">
                    <span class="detail-label">Nom</span>
                    <strong>{{ offer.entreprise_nom ?: 'Non défini' }}</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Secteur</span>
                    <strong>{{ offer.entreprise_secteur ?: 'Non défini' }}</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Ville</span>
                    <strong>{{ offer.entreprise_ville ?: 'Non définie' }}</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">SIRET</span>
                    <strong>{{ offer.entreprise_siret ?: 'Non renseigné' }}</strong>
                </div>

                <div class="detail-info-item">
                    <span class="detail-label">Évaluation</span>
                    {% if offer.entreprise_note is not null %}
                        <div class="stars-display" style="margin-top: 4px;">
                            {% set note_int = offer.entreprise_note|round(0, 'floor') %}
                            {% for i in 1..5 %}
                                <span class="star-icon {% if i <= note_int %}star-filled{% else %}star-empty{% endif %}">&#9733;</span>
                            {% endfor %}
                            <small class="stars-number">{{ note_int }}/5</small>
                        </div>
                    {% else %}
                        <strong style="color: #9ca3af;">Non évaluée</strong>
                    {% endif %}
                </div>
            </div>

            {% if offer.entreprise_site_web %}
                <p>
                    <strong>Site web :</strong>
                    <a href="{{ offer.entreprise_site_web }}" target="_blank" rel="noopener noreferrer">
                        {{ offer.entreprise_site_web }}
                    </a>
                </p>
            {% endif %}

            <h2>Derniers commentaires</h2>

            {% if latest_comments is not empty %}
                <div style="display:flex; flex-direction:column; gap:16px; margin-top:16px;">
                    {% for comment in latest_comments %}
                        <div style="padding:16px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:12px;">
                            <div style="display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:8px;">
                                <strong>
                                    {% if comment.prenom or comment.nom %}
                                        {{ comment.prenom }} {{ comment.nom }}
                                    {% elseif comment.email %}
                                        {{ comment.email }}
                                    {% else %}
                                        Utilisateur #{{ comment.user_id ?: 'inconnu' }}
                                    {% endif %}
                                </strong>

                                <small style="color:#6b7280;">
                                    {{ comment.created_at|date('d/m/Y H:i') }}
                                </small>
                            </div>

                            <p style="margin:0; white-space:pre-line;">{{ comment.commentaire }}</p>
                        </div>
                    {% endfor %}
                </div>

                {% if offer.entreprise_id and comments_count > 3 %}
                    <div style="margin-top:20px;">
                        <a href="/entreprises/{{ offer.entreprise_id }}/commentaires" class="secondary-button">
                            Voir plus de commentaires
                        </a>
                    </div>
                {% endif %}
            {% else %}
                <p style="color:#6b7280;">Aucun commentaire pour cette entreprise.</p>
            {% endif %}

            {% if current_user and current_user.role == 'etudiant' %}
                <div class="detail-actions">
                    {% if is_in_wishlist %}
                        <form method="POST" action="/offres/{{ offer.id }}/wishlist/supprimer">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="secondary-button">Retirer de ma wishlist</button>
                        </form>
                    {% else %}
                        <form method="POST" action="/offres/{{ offer.id }}/wishlist/ajouter">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="secondary-button">Ajouter à ma wishlist</button>
                        </form>
                    {% endif %}
                </div>
            {% endif %}

            <div class="detail-actions">
                {% if current_user is null %}
                    <a href="/connexion" class="apply-button">Se connecter pour postuler</a>
                    <p class="detail-note">Connexion requise pour postuler à cette offre</p>
                {% elseif current_user.role != 'etudiant' %}
                    <button class="apply-button disabled-button" disabled>Réservé aux étudiants</button>
                {% elseif has_applied %}
                    <button class="apply-button disabled-button" disabled>Déjà postulé</button>
                {% else %}
                    <a href="/offres/{{ offer.id }}/postuler" class="apply-button">Postuler</a>
                    <p class="detail-note">Votre candidature sera ajoutée à votre espace étudiant</p>
                {% endif %}
            </div>
        </section>
    </div>
</main>
{% endblock %}