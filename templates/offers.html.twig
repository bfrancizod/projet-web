{% extends 'base.html.twig' %}

{% block title %}Offres - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/offers.css">
{% endblock %}

{% block body %}
<main class="offers-page">
    <div class="container offers-layout">
        <aside class="filters">
            <h3>Filtres</h3>

            <form method="GET" action="/offres">
                <div>
                    <label for="search_query">Recherche</label>
                    <input
                        id="search_query"
                        type="text"
                        name="search_query"
                        value="{{ search_query }}"
                        placeholder="Titre, entreprise, mot-clé..."
                    >
                </div>

                <div>
                    <label for="skills">Compétences</label>
                    <input
                        id="skills"
                        type="text"
                        name="skills"
                        value="{{ skills_query }}"
                        placeholder="Ex: React, Python, JS (séparées par des virgules)"
                    >
                </div>

                <div>
                    <label for="location">Lieu</label>
                    <input
                        id="location"
                        type="text"
                        name="location"
                        value="{{ location_query }}"
                        placeholder="Ex: Paris, Lyon"
                    >
                </div>

                <div>
                    <label for="duration">Durée maximum</label>
                    <select id="duration" name="duration">
                        <option value="">Toutes les durées</option>
                        <option value="8" {% if duration_query == '8' %}selected{% endif %}>8 semaines max</option>
                        <option value="10" {% if duration_query == '10' %}selected{% endif %}>10 semaines max</option>
                        <option value="12" {% if duration_query == '12' %}selected{% endif %}>12 semaines max</option>
                        <option value="16" {% if duration_query == '16' %}selected{% endif %}>16 semaines max</option>
                    </select>
                </div>

                <div>
                    <label for="salary">Rémunération minimum</label>
                    <select id="salary" name="salary">
                        <option value="">Toutes les rémunérations</option>
                        <option value="500" {% if salary_query == '500' %}selected{% endif %}>500 €</option>
                        <option value="600" {% if salary_query == '600' %}selected{% endif %}>600 €</option>
                        <option value="700" {% if salary_query == '700' %}selected{% endif %}>700 €</option>
                        <option value="800" {% if salary_query == '800' %}selected{% endif %}>800 €</option>
                    </select>
                </div>

                <div>
                    <label for="sort">Trier par</label>
                    <select id="sort" name="sort">
                        <option value="recent" {% if sort_query == 'recent' %}selected{% endif %}>Plus récentes</option>
                        <option value="salary_asc" {% if sort_query == 'salary_asc' %}selected{% endif %}>Salaire croissant</option>
                        <option value="salary_desc" {% if sort_query == 'salary_desc' %}selected{% endif %}>Salaire décroissant</option>
                        <option value="duration_asc" {% if sort_query == 'duration_asc' %}selected{% endif %}>Durée croissante</option>
                        <option value="duration_desc" {% if sort_query == 'duration_desc' %}selected{% endif %}>Durée décroissante</option>
                    </select>
                </div>

                <button type="submit" class="cta-button filter-btn">Filtrer</button>
                <a href="/offres" class="student-link">Réinitialiser</a>
            </form>
        </aside>

        <section class="offers-list">
            <h1>Offres de stage</h1>

            <div class="offers-grid">
                {% for offer in offers %}
                    <article class="offer-card">
                        <div class="offer-header">
                            <h3>{{ offer.titre }}</h3>
                        </div>

                        <p class="company">{{ offer.entreprise_nom ?: 'Entreprise non définie' }}</p>
                        <p>
                            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                            {{ offer.lieu ?: 'Lieu non défini' }}
                        </p>
                        <p>◦ {{ offer.duree_semaines }} semaines</p>
                        <p>
                            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
                            {{ offer.remuneration }} €
                        </p>

                        <div class="tags">
                            {% for skill in offer.skills %}
                                <span class="tag">{{ skill.nom }}</span>
                            {% endfor %}
                        </div>

                        <a href="/offres/{{ offer.id }}" class="offer-button">Voir l'offre</a>
                    </article>
                {% else %}
                    <p class="empty-state">Aucune offre trouvée.</p>
                {% endfor %}
            </div>

            {% if total_pages > 1 %}
                <div class="pagination">
                    {% for p in 1..total_pages %}
                        <a
                            class="page {% if p == current_page %}active{% endif %}"
                            href="/offres?page={{ p }}&search_query={{ search_query|url_encode }}&skills={{ skills_query|url_encode }}&location={{ location_query|url_encode }}&duration={{ duration_query|url_encode }}&salary={{ salary_query|url_encode }}&sort={{ sort_query|url_encode }}"
                        >
                            {{ p }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </div>
</main>
{% endblock %}