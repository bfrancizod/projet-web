{#
    Tableau de bord de l'espace étudiant.

    Variables transmises par StudentDashboardController:index() :
     - stats.applications   : nombre total de candidatures de l'étudiant
     - stats.wishlist        : nombre d'offres dans sa wishlist
     - recent_applications  : 3 dernières candidatures avec titre, entreprise, date et statut
#}
{% extends 'base.html.twig' %}

{% block title %}Espace étudiant - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/student-dashboard.css">
{% endblock %}

{% block body %}
<div class="student-page">
    <div class="student-container">

        <div class="student-header">
            <h1>Mon tableau de bord</h1>
        </div>

        <section class="student-stats">
            <article class="student-stat-card">
                <div class="student-stat-icon" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.51 15.49 0 12.36 0c-1.5 0-2.92.6-3.97 1.66L6 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zM8.83 3.08C9.5 2.4 10.39 2 11.36 2c1.92 0 3.5 1.56 3.5 3.5 0 .36-.06.7-.17 1.02L8.83 3.08zM12 18c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg>
                </div>
                <div>
                    <span>Mes candidatures</span>
                    <strong>{{ stats.applications }}</strong>
                </div>
            </article>

            <article class="student-stat-card">
                <div class="student-stat-icon" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                </div>
                <div>
                    <span>Ma wishlist</span>
                    <strong>{{ stats.wishlist }}</strong>
                </div>
            </article>
        </section>

        <section class="student-section">
            <div class="student-section-header">
                <h2>Statistiques des offres</h2>
                <a href="/statistiques-offres">Voir la page</a>
            </div>

            <div class="student-list">
                <article class="student-row">
                    <div class="student-main">
                        <h3>Consulter les indicateurs clés</h3>
                        <p>Retrouve le total des offres, la moyenne de candidatures, la répartition par durée et le top wishlist.</p>
                    </div>

                    <a href="/statistiques-offres" class="student-button">Ouvrir</a>
                </article>
            </div>
        </section>

        <section class="student-section">
            <div class="student-section-header">
                <h2>Candidatures récentes</h2>
                <a href="/etudiant-candidatures">Voir tout</a>
            </div>

            <div class="student-list">
                {#
                    Badges de statut — 4 états possibles issus de la table candidatures.status :
                     envoyee  → badge jaune (en attente de traitement par le pilote)
                     en_etude → badge vert  (candidature examinée par le pilote)
                     acceptee → badge bleu  (stage accepté)
                     refusee  → badge rouge (candidature refusée)
                #}
                {% for application in recent_applications %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ application.titre }}</h3>
                            <p>{{ application.entreprise }}</p>
                            <small>Postulé le {{ application.created_at|date('d/m/Y') }}</small>
                        </div>

                        {% if application.status == 'envoyee' %}
                            <span class="badge badge-yellow">En attente</span>
                        {% elseif application.status == 'en_etude' %}
                            <span class="badge badge-green">En cours</span>
                        {% elseif application.status == 'acceptee' %}
                            <span class="badge badge-blue">Acceptée</span>
                        {% elseif application.status == 'refusee' %}
                            <span class="badge badge-red">Refusée</span>
                        {% endif %}
                    </article>
                {% else %}
                    <p class="empty-state">Aucune candidature pour le moment.</p>
                {% endfor %}
            </div>
        </section>

    </div>
</main>
{% endblock %}